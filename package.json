{
  "name": "codex-mem",
  "version": "0.1.0",
  "description": "Persistent memory for OpenAI Codex workflows",
  "bin": {
    "codex-mem": "dist/cli.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "dev": "tsc -w -p tsconfig.json",
    "worker": "node dist/worker.js",
    "hook:session-start": "node dist/hooks/session-start.js",
    "hook:prompt-submit": "node dist/hooks/prompt-submit.js",
    "hook:post-tool-use": "node dist/hooks/post-tool-use.js",
    "hook:stop": "node dist/hooks/stop.js",
    "hook:session-end": "node dist/hooks/session-end.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "sql.js": "^1.10.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/sql.js": "^1.4.7",
    "typescript": "^5.6.3"
  }
}
